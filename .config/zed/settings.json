// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
	"agent_servers": {
		"codex-acp": {
			"type": "registry"
		}
	},
	"context_servers": {
		"drwaio": {
			"enabled": true,
			"remote": false,
			"command": "bunx",
			"args": ["-y", "@drawio/mcp"],
			"env": {}
		},
		"next-devtools": {
			"enabled": true,
			"remote": false,
			"command": "bunx",
			"args": ["-y", "next-devtools-mcp@latest"]
		}
	},
	"lsp": {
		"vtsls": {
			"settings": {
				"typescript": {
					"updateImportsOnFileMove": {
						"enabled": "always"
					}
				},
				"javascript": {
					"updateImportsOnFileMove": {
						"enabled": "always"
					}
				}
			},
			"enable_lsp_tasks": true
		},
		"texlab": {
			"settings": {
				"texlab": {
					"build": {
						"executable": "latexmk",
						"args": ["-cd", "%f"],
						"auxDirectory": ".tex",
						"logDirectory": ".tex",
						"pdfDirectory": "dist",
						"forwardSearchAfter": false,
						"onSave": true
					},
					"latexFormatter": "latexindent",
					"latexindent": {
						"local": "localSettings.yaml",
						"replacement": "-r"
					},
					"chktex": {
						// "onOpenAndSave": true,
						// "onEdit": true
					}
				}
			}
		},
		"biome": {
			"settings": {
				// "require_config_file": true
			}
		},
		"mpls": {
			"binary": {
				// "path": "/usr/local/bin/mpls"
			}
		}
	},
	"terminal": {
		"dock": "bottom",
		"font_size": 12.0
	},
	"dev_container_connections": [],

	"format_on_save": "on",
	"languages": {
		"C": {
			"format_on_save": "on",
			"tab_size": 2
		},
		"LaTeX": {
			"tab_size": 2,
			"soft_wrap": "editor_width"
		},
		"Python": {
			"language_servers": ["basedpyright", "ruff"]
		},
		"Markdown": {
			"format_on_save": "on",
			"show_edit_predictions": true
		},
		"JSON": {
			"tab_size": 2,
			"formatter": { "language_server": { "name": "biome" } }
		},
		"JavaScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TypeScript": {
			"tab_size": 2,
			"formatter": {
				"language_server": { "name": "biome" }
			}
		},
		"TSX": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"CSS": { "formatter": { "language_server": { "name": "biome" } } },
		"HTML": {
			"tab_size": 2,
			"formatter": "prettier"
		},
		"TOML": {
			"formatter": "language_server"
		}
	},
	"edit_predictions": {
		"provider": "copilot",
		"disabled_globs": [],
		"mode": "eager"
	},
	"show_completions_on_input": true,
	"agent": {
		"tool_permissions": {
			"default": "allow"
		},
		"default_profile": "write",
		"default_model": {
			"provider": "copilot_chat",
			"model": "claude-opus-4.6"
		},
		"model_parameters": []
	},
	"icon_theme": "Colored Zed Icons Theme Dark",
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"base_keymap": "VSCode",
	"minimap": {
		"show": "never"
	},
	"diagnostics": {
		"inline": {
			"enabled": true
		}
	},
	"relative_line_numbers": "enabled",
	"auto_indent_on_paste": true,
	"linked_edits": true,
	"show_edit_predictions": true,
	"ensure_final_newline_on_save": true,
	"indent_guides": {
		"enabled": true
	},
	"tab_size": 4,
	"vim_mode": true,
	"ui_font_size": 15.0,
	"buffer_font_size": 12.0,
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "Ayu Dark"
	},
	"experimental.theme_overrides": {
		"renamed.background": "#FFFFFF20",
		"search.match_background": "#FFFFFF20",
		"ghost_element.background": "#00000010",
		"ghost_element.hover": "#00000099",
		"background.appearance": "blurred",
		"background": "#000000CC",
		"editor.background": "#00000010",
		"editor.gutter.background": "#00000010",
		"title_bar.background": "#000000DF",
		"toolbar.background": "#00000010",
		"terminal.background": "#00000000",
		"status_bar.background": "#000000DF",
		"tab.active_background": "#000000",
		"tab.inactive_background": "#00000000",
		"tab_bar.background": "#00000010",
		"panel.background": "#00000010",
		"border": "#00000000",
		"border.variant": "#00000000",
		"scrollbar.track.border": "#00000000",
		"scrollbar.track.background": "#00000000",
		"scrollbar.thumb.background": "#00000000",
		// "scrollbar.thumb.hover.background": "#00000000",
		// "scrollbar.thumb.active.background": "#00000000",
		"scrollbar.thumb.border": "#FFFFFF90",
		// "editor.line_highlight": "#00000000",
		"editor.active_line.background": "#00000000"
		// "editor.selection.background": "#00000000",
		// "editor.selection.foreground": "#00000000",
		// "editor.selection.border": "#00000000",
		// "editor.selection.inactive.foreground": "#00000000",
		// "editor.selection.inactive.border": "#00000000",
		// "editor.selection.active.background": "#00000000",
		// "editor.selection.active.foreground": "#00000000",
		// "editor.selection.active.border": "#00000000",
		// "editor.selection.inactive.background": "#00000000"
	}
}
